# CryptoVerse Environment Configuration
# Copy this to .env and customize

# Server
PORT=3000

# Ethereum RPC (get free keys from infura.io or alchemy.com)
# Leave empty to use public RPC endpoints
ETH_RPC_URL=
POLYGON_RPC_URL=
BSC_RPC_URL=

# CoinGecko API (optional, free tier works without key)
COINGECKO_API_KEY=

# Whale Alert threshold (in ETH)
WHALE_THRESHOLD=10
